{
  "cli": {
    "version": ">= 15.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "node": "22.12.0",
      "env": {
        "EAS_BUILD_INSTALL_COMMAND": "npm install --legacy-peer-deps"
      },
      "ios": {
        "simulator": true
      }
    },
    "preview": {
      "distribution": "internal",
      "node": "22.12.0",
      "env": {
        "EAS_BUILD_INSTALL_COMMAND": "npm install --legacy-peer-deps"
      }
    },
    "production": {
      "autoIncrement": true,
      "node": "22.12.0",
      "env": {
        "EAS_BUILD_INSTALL_COMMAND": "npm install --legacy-peer-deps"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
